VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-anon-aqui

# URL absoluta del sitio en producción (sin barra al final).
# Se inyecta en index.html para que los previews de WhatsApp, Telegram,
# Facebook y X carguen og:image y og:url con URLs absolutas.
# En Vercel: definir en Project Settings → Environment Variables.
VITE_SITE_URL=https://lacopafamiliar.vercel.app

# Solo necesaria para que el deploy aplique los .sql de /supabase automáticamente.
# Supabase → Project Settings → Database → Connection string → URI
#
# IMPORTANTE para Vercel: usa el POOLER (puerto 6543). La conexión directa
# (db.PROYECTO.supabase.co:5432) es IPv6-only en proyectos nuevos y los build
# hosts de Vercel son IPv4-only, así que falla.
SUPABASE_DB_URL=postgresql://postgres.TU-PROYECTO:TU-PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
